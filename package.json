{
  "name": "hammadev",
  "version": "0.1.0-alpha.0",
  "description": "Local handoff and shared-memory CLI for Codex and Claude Code",
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "hamma": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xayrullonematov/hammadev.git"
  },
  "bugs": {
    "url": "https://github.com/xayrullonematov/hammadev/issues"
  },
  "homepage": "https://github.com/xayrullonematov/hammadev#readme",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "smoke:cli": "pnpm build && node dist/cli.js --help",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "cli",
    "codex",
    "claude",
    "handoff",
    "agents",
    "developer-tools"
  ],
  "license": "ISC",
  "dependencies": {
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "type": "module",
  "packageManager": "pnpm@10.15.0"
}